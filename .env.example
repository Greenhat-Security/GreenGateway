# Address the gateway listens on.
# Default: 0.0.0.0:8080
LISTEN_ADDR=0.0.0.0:8080

# Optional address for serving only the admin UI/control-plane API.
# Default: empty (admin surface served on LISTEN_ADDR)
ADMIN_LISTEN_ADDR=

# Gateway admin UI/control-plane prefix.
# Default: /admin
ADMIN_PREFIX=/admin

# Optional admin UI OIDC login provider name. Must reference a jwt AUTH_PROVIDERS entry with issuer, client_id, client_secret, and redirect_uri.
# Default: empty (SSO login disabled; manual bearer-token paste still works)
ADMIN_LOGIN_PROVIDER=

# Optional public base URL clients use to reach this gateway.
# Enables MCP OAuth protected-resource discovery and resource-bound JWT audience checks for /mcp.
# Example: https://gateway.example.com
# Default: empty (OAuth protected-resource metadata disabled)
GATEWAY_PUBLIC_URL=

# Optional JSONL audit log file. Audit events are always written to stdout.
# Default: empty (no file sink)
AUDIT_LOG_FILE=

# Optional SQLite audit event store path for queryable local audit history.
# Default: empty (SQLite sink disabled)
AUDIT_SQLITE_PATH=

# Optional SQLite audit event retention window, in days. Ignored unless AUDIT_SQLITE_PATH is set.
# Default: empty (no SQLite pruning)
AUDIT_SQLITE_RETENTION_DAYS=

# Optional SQLite endpoint discovery inventory store. Leave empty to disable aggregation.
# Default: empty (discovery aggregation disabled)
DISCOVERY_SQLITE_PATH=

# Maximum distinct (method, endpoint_template) aggregates retained in memory and
# in DISCOVERY_SQLITE_PATH. Least-recently-observed endpoints are evicted when
# the cap is reached. Must be greater than 0.
# Default: 10000
DISCOVERY_ENDPOINT_LIMIT=10000

# Optional SQLite principal directory store. Leave empty to disable identity persistence.
# Default: empty (principal directory disabled)
PRINCIPAL_SQLITE_PATH=

# Explicit opt-in for sampled request-shape capture into DISCOVERY_SQLITE_PATH.
# Default: false
PAYLOAD_CAPTURE_ENABLED=false

# Deterministic per-request payload capture sample rate. Must be >= 0.0 and < 1.0.
# Default: 0.10
PAYLOAD_CAPTURE_SAMPLE_RATE=0.10

# Cumulative schema mismatch count that opens a schema_mismatch discovery signal.
# Default: 5
SCHEMA_MISMATCH_SIGNAL_THRESHOLD=5

# Error-rate delta, as a ratio, that opens an error_rate_spike discovery signal.
# Default: 0.40
ERROR_RATE_SPIKE_SIGNAL_THRESHOLD=0.40

# Prior distinct principal count required before a new principal/endpoint pair opens a signal.
# Default: 1
PRINCIPAL_NEW_TO_ENDPOINT_SIGNAL_THRESHOLD=1

# Per-endpoint volume multiple that opens a volume_outlier discovery signal.
# Default: 3.0
VOLUME_OUTLIER_SIGNAL_THRESHOLD=3.0

# Lookback window used by explicit rule suggestion generation for baseline allow candidates.
# Default: 24
RULE_SUGGESTION_BASELINE_WINDOW_HOURS=24

# Optional local OpenAPI 3.x JSON or YAML spec for the legacy single UPSTREAM_URL mode.
# Default: empty (schema coverage disabled unless UPSTREAM_ROUTES entries set openapi_spec_path)
OPENAPI_SPEC_PATH=

# Optional RBAC policy JSON file loaded by authorization middleware.
# Default: empty (RBAC disabled)
POLICY_FILE=

# Optional tool definition registry JSON file. Leave empty to disable dynamic tools.
# Default: empty (tool registry disabled)
TOOLS_FILE=

# Optional upstream MCP servers to discover and proxy as namespaced tools.
# JSON array entries require name and url; optional timeout_ms, response_idle_timeout_ms, and connect_timeout_ms override egress defaults for that MCP server.
# Upstream MCP hosts must still be allowed by EGRESS_ALLOWED_HOSTS or policy egress hosts; they are not auto-seeded.
# Example: [{"name":"prod","url":"https://mcp.example.test/mcp","timeout_ms":5000}]
# Default: empty
MCP_UPSTREAM_SERVERS=

# Optional SQLite policy version history store.
# Default: empty (derive POLICY_FILE.history.sqlite when POLICY_FILE is set)
POLICY_HISTORY_SQLITE_PATH=

# Comma-separated paths exempt from RBAC authorization.
# Default: /health,/version,/metrics plus ADMIN_PREFIX; when ADMIN_LOGIN_PROVIDER is set, also /v1{ADMIN_PREFIX}/auth/login and /v1{ADMIN_PREFIX}/auth/callback
RBAC_EXEMPT_PATHS=/health,/version,/metrics,/admin

# Comma-separated CORS origins allowed to read gateway responses.
# Default: empty (no cross-origin browser access allowed)
CORS_ALLOW_ORIGINS=

# Maximum request body size accepted from Content-Length, in bytes.
# Default: 1048576 (1 MiB)
MAX_BODY_SIZE=1048576

# Read-lane token refill rate for GET and HEAD requests, in requests per second.
# Default: 50.0
RATE_LIMIT_READ_RPS=50.0

# Read-lane token bucket burst size for GET and HEAD requests.
# Default: 100
RATE_LIMIT_READ_BURST=100

# Write-lane token refill rate for non-GET/HEAD requests, in requests per second.
# Default: 10.0
RATE_LIMIT_WRITE_RPS=10.0

# Write-lane token bucket burst size for non-GET/HEAD requests.
# Default: 20
RATE_LIMIT_WRITE_BURST=20

# Allow trusted direct proxy peers to supply X-Forwarded-For or X-Real-IP.
# Default: false
TRUST_PROXY_HEADERS=false

# Comma-separated CIDRs for direct proxy peers whose forwarding headers are trusted.
# Required when TRUST_PROXY_HEADERS=true. Default: empty
TRUSTED_PROXY_CIDRS=

# Comma-separated Content-Type prefixes accepted for POST, PUT, and PATCH requests.
# Default: application/json
VALIDATION_ALLOWED_CONTENT_TYPES=application/json

# Enable global authentication middleware.
# Default: true
AUTH_ENABLED=true

# Authentication enforcement mode: required or observe.
# Default: required
AUTH_MODE=required

# Session cookie name used as an auth credential.
# Default: session
AUTH_COOKIE_NAME=session

# Comma-separated paths exempt from authentication.
# Default: /health,/version,/metrics plus ADMIN_PREFIX; when ADMIN_LOGIN_PROVIDER is set, also /v1{ADMIN_PREFIX}/auth/login and /v1{ADMIN_PREFIX}/auth/callback
AUTH_EXEMPT_PATHS=/health,/version,/metrics,/admin

# Ordered JSON array of auth providers. When empty, the legacy JWT_* settings below are used as an implicit single provider if JWT_JWKS_URL is set.
# Provider types: jwt or cookie_session.
# JWT providers must set jwks_url or issuer. When jwks_url is omitted, issuer is used for OIDC discovery at {issuer}/.well-known/openid-configuration.
# A jwt provider selected by ADMIN_LOGIN_PROVIDER must also set client_id, client_secret, and redirect_uri; its discovery document must include authorization_endpoint and token_endpoint.
# cookie_session providers must set introspection_url and user_id_claim. GreenGateway POSTs {"session":"<cookie value>"} and maps the JSON response with the claim fields below.
# Provider endpoint hosts, including an ADMIN_LOGIN_PROVIDER's discovered token_endpoint host, are added to the effective egress allowlist; non-global-IP and scheme checks still apply.
# roles_claim, org_claim, user_id_claim, and email_claim first resolve exact top-level keys, then fall back to dotted nested paths when no exact key exists.
# roles_claim_delimiter splits string role claims such as scope="read write"; arrays ignore the delimiter. org_claim maps a string claim to Principal.org_id.
# Example: [{"name":"primary","type":"jwt","issuer":"https://idp.example.com","audience":"greengateway","roles_claim":"roles","require_jti":false}]
# Admin UI SSO example: set ADMIN_LOGIN_PROVIDER=primary and add {"client_id":"greengateway-admin","client_secret":"placeholder-secret","redirect_uri":"https://gateway.example.com/v1/admin/auth/callback"} to that jwt provider.
# Nested roles example: [{"name":"keycloak","type":"jwt","issuer":"https://keycloak.example.com/realms/acme","audience":"greengateway","roles_claim":"realm_access.roles","org_claim":"tenant.id"}]
# Scope roles example: [{"name":"oauth","type":"jwt","issuer":"https://idp.example.com","audience":"greengateway","roles_claim":"scope","roles_claim_delimiter":" "}]
# Namespaced literal claim example: [{"name":"auth0","type":"jwt","issuer":"https://tenant.auth0.com/","audience":"https://api.example.com","roles_claim":"https://myapp.example.com/roles","org_claim":"https://myapp.example.com/org_id"}]
# Cookie session example: [{"name":"app","type":"cookie_session","introspection_url":"https://app.example.com/session/introspect","user_id_claim":"account.id","email_claim":"account.email","roles_claim":"account.scope","roles_claim_delimiter":" ","org_claim":"account.tenant_id","cache_ttl_ms":5000}]
# Default: empty
AUTH_PROVIDERS=

# Optional JWKS endpoint used to validate bearer JWTs.
# Default: empty (JWT validator disabled)
JWT_JWKS_URL=

# Optional expected JWT issuer.
# Default: empty (issuer is not checked)
JWT_ISSUER=

# Optional expected JWT audience.
# Default: empty (audience is not checked)
JWT_AUDIENCE=

# Timeout for JWKS fetches, in milliseconds.
# Default: 2000
JWT_JWKS_TIMEOUT_MS=2000

# Require bearer JWTs to include a non-empty jti claim.
# Default: false
JWT_REQUIRE_JTI=false

# JWT role claim key or dotted path. Exact top-level keys win before dotted path fallback, so Auth0-style URL claim keys remain literal.
# Legacy ROLES_CLAIM extracts arrays of strings only; use AUTH_PROVIDERS roles_claim_delimiter for string scope claims.
# Default: roles
ROLES_CLAIM=roles

# Optional SQLite store path for service tokens created by the admin API and accepted as ggw_ bearer credentials.
# Default: empty (service-token API and validator disabled)
SERVICE_TOKEN_SQLITE_PATH=

# Service-token verification cache TTL, in milliseconds. Revocations made outside this process can remain accepted until this window expires.
# Default: 5000
SERVICE_TOKEN_CACHE_TTL_MS=5000

# Maximum queued plus running tool invocations admitted by the generic tool runtime.
# Default: 1024
TOOL_RUNTIME_QUEUE_DEPTH=1024

# Maximum concurrently executing tool invocations across all tools.
# Default: 64
TOOL_RUNTIME_GLOBAL_CONCURRENCY=64

# Maximum time a queued tool invocation waits for execution permits, in milliseconds.
# Default: 1000
TOOL_RUNTIME_QUEUE_TIMEOUT_MS=1000

# Default execution timeout for generic tool runtime invocations, in milliseconds.
# Default: 30000
TOOL_RUNTIME_DEFAULT_TIMEOUT_MS=30000

# Enable double-submit CSRF checks for gateway control-plane state-changing requests.
# Default: true
CSRF_ENABLED=true

# CSRF token cookie name. This cookie is intentionally readable by browser JavaScript.
# Default: csrf_token
CSRF_COOKIE_NAME=csrf_token

# Request header that must echo the CSRF cookie token for protected state-changing requests.
# Default: x-csrf-token
CSRF_HEADER_NAME=x-csrf-token

# Optional Domain attribute for the CSRF cookie. Leave empty to omit Domain.
# Default: empty
CSRF_COOKIE_DOMAIN=

# Comma-separated paths exempt from CSRF checks.
# Default: /health,/version,/metrics
CSRF_EXEMPT_PATHS=/health,/version,/metrics

# Optional upstream origin for catch-all reverse proxy fallback. Leave empty to disable proxying.
# Default: empty
UPSTREAM_URL=

# Optional ordered routing table as a JSON array. Mutually exclusive with UPSTREAM_URL.
# Route entries may include timeout_ms, response_idle_timeout_ms, connect_timeout_ms,
# add_request_headers, strip_request_headers, tls_ca_bundle_path, and openapi_spec_path.
# Example: [{"path_prefix":"/api","upstream_url":"https://api.example.test","timeout_ms":1500,"add_request_headers":{"x-gateway-upstream":"api"},"strip_request_headers":["x-client-secret"],"tls_ca_bundle_path":"/etc/greengateway/internal-ca.pem","openapi_spec_path":"/etc/greengateway/api.openapi.yaml"},{"host":"app.example.test","path_prefix":"/","upstream_url":"https://app.example.test"}]
# Default: empty
UPSTREAM_ROUTES=

# Optional total timeout override for configured upstream proxy requests, in milliseconds.
# Default: empty (inherits EGRESS_TIMEOUT_MS)
UPSTREAM_TIMEOUT_MS=

# Optional streamed response idle timeout override for configured upstream proxy requests, in milliseconds.
# Default: empty (inherits EGRESS_RESPONSE_IDLE_TIMEOUT_MS)
UPSTREAM_RESPONSE_IDLE_TIMEOUT_MS=

# Optional TCP/TLS connection timeout override for configured upstream proxy requests, in milliseconds.
# Default: empty (inherits EGRESS_CONNECT_TIMEOUT_MS)
UPSTREAM_CONNECT_TIMEOUT_MS=

# Comma-separated outbound hostnames the egress client may call. Empty denies all.
# Default: empty (deny all gateway-originated outbound HTTP)
EGRESS_ALLOWED_HOSTS=

# Total timeout for each egress HTTP request, in milliseconds.
# Default: 30000
EGRESS_TIMEOUT_MS=30000

# Idle timeout between streamed egress response body chunks, in milliseconds.
# Default: 30000
EGRESS_RESPONSE_IDLE_TIMEOUT_MS=30000

# TCP/TLS connection timeout for each egress HTTP request, in milliseconds.
# Default: 10000
EGRESS_CONNECT_TIMEOUT_MS=10000

# Maximum egress response body bytes buffered while streaming.
# Default: 5242880 (5 MiB)
EGRESS_MAX_RESPONSE_BYTES=5242880

# Maximum egress request body bytes allowed before send.
# Default: 1048576 (1 MiB)
EGRESS_MAX_REQUEST_BODY_BYTES=1048576

# Optional RFC 6052 network-specific NAT64 prefixes. The well-known 64:ff9b::/96 prefix is built in.
# Allowed prefix lengths: 32, 40, 48, 56, 64, or 96. The RFC 6052 u octet must be zero.
# Prefixes must not overlap each other or the built-in well-known prefix.
# Default: empty
EGRESS_NAT64_PREFIXES=

# Block non-global and special-use resolved IPs, including private, loopback, link-local, CGNAT, documentation, benchmarking, multicast, and reserved ranges.
# Default: true
EGRESS_DENY_PRIVATE_IPS=true
