# Address the gateway listens on.
# Default: 0.0.0.0:8080
LISTEN_ADDR=0.0.0.0:8080

# Comma-separated CORS origins allowed to read gateway responses.
# Default: empty (no cross-origin browser access allowed)
CORS_ALLOW_ORIGINS=

# Maximum request body size accepted from Content-Length, in bytes.
# Default: 1048576 (1 MiB)
MAX_BODY_SIZE=1048576

# Read-lane token refill rate for GET and HEAD requests, in requests per second.
# Default: 50.0
RATE_LIMIT_READ_RPS=50.0

# Read-lane token bucket burst size for GET and HEAD requests.
# Default: 100
RATE_LIMIT_READ_BURST=100

# Write-lane token refill rate for non-GET/HEAD requests, in requests per second.
# Default: 10.0
RATE_LIMIT_WRITE_RPS=10.0

# Write-lane token bucket burst size for non-GET/HEAD requests.
# Default: 20
RATE_LIMIT_WRITE_BURST=20

# Trust X-Forwarded-For and X-Real-IP as canonical client IP inputs.
# Default: false
TRUST_PROXY_HEADERS=false

# Keep empty until sessions are validated upstream; see docs/configuration.md security note.
# Default: empty (client IP keying only)
SESSION_COOKIE_NAME=

# Comma-separated Content-Type prefixes accepted for POST, PUT, and PATCH requests.
# Default: application/json
VALIDATION_ALLOWED_CONTENT_TYPES=application/json

# Enable double-submit CSRF checks for gateway control-plane state-changing requests.
# Default: true
CSRF_ENABLED=true

# CSRF token cookie name. This cookie is intentionally readable by browser JavaScript.
# Default: csrf_token
CSRF_COOKIE_NAME=csrf_token

# Request header that must echo the CSRF cookie token for protected state-changing requests.
# Default: x-csrf-token
CSRF_HEADER_NAME=x-csrf-token

# Optional Domain attribute for the CSRF cookie. Leave empty to omit Domain.
# Default: empty
CSRF_COOKIE_DOMAIN=

# Comma-separated paths exempt from CSRF checks.
# Default: /health,/version,/metrics
CSRF_EXEMPT_PATHS=/health,/version,/metrics
