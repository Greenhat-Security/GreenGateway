{
  "schema_version": "0.1.0",
  "id": "dev-control-plane",
  "default_action": "deny",
  "roles": {
    "admin": {
      "permissions": ["*"]
    },
    "reader": {
      "permissions": []
    }
  },
  "routes": [
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/audit",
      "permission": "admin:audit:read"
    },
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/events/stream",
      "permission": "admin:audit:stream"
    },
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/status",
      "permission": "admin:status:read"
    },
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/policy",
      "permission": "admin:policy:read"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/v1/admin/policy/validate",
      "permission": "admin:policy:read"
    },
    {
      "methods": ["PUT", "POST", "PATCH", "DELETE"],
      "path_prefix": "/v1/admin/policy",
      "permission": "admin:policy:write"
    },
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/signals",
      "permission": "admin:signals:read"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/v1/admin/signals",
      "permission": "admin:signals:write"
    },
    {
      "methods": ["GET"],
      "path_prefix": "/v1/admin/traffic",
      "permission": "admin:traffic:read"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/v1/admin/tools/openapi/preview",
      "permission": "admin:tools:read"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/v1/admin/tools/openapi/register",
      "permission": "admin:tools:write"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/v1/admin/traffic/endpoints/review",
      "permission": "admin:traffic:write"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/__dev-echo",
      "permission": "dev:proxy:echo"
    },
    {
      "methods": ["POST"],
      "path_prefix": "/mcp",
      "permission": "admin:mcp:use"
    }
  ],
  "tools": {
    "echo": {
      "allowed_roles": ["admin"]
    },
    "get_widget": {
      "allowed_roles": ["admin"]
    }
  }
}
